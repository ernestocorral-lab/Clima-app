{
  "expo": {
    "name": "Clima multiciudad",
    "slug": "weather-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "clima",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.weatherapp.clima",
      "versionCode": 7,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "INTERNET"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0B1D3A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TemperatureWidget",
              "label": "Clima",
              "description": "Gráfico del clima de una ciudad (temperatura, humedad, viento…)",
              "previewImage": "./assets/widget-preview/temperature-widget.png",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "widgetFeatures": "reconfigurable|configuration_optional",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "MetricWidget",
              "label": "Medida actual",
              "description": "Valor actual de una medida del clima (temperatura, humedad, UV…)",
              "previewImage": "./assets/widget-preview/metric-widget.png",
              "minWidth": "40dp",
              "minHeight": "40dp",
              "targetCellWidth": 1,
              "targetCellHeight": 1,
              "widgetFeatures": "reconfigurable|configuration_optional",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "CitySummaryWidget",
              "label": "Resumen ciudad",
              "description": "Condiciones actuales de una ciudad (como el recuadro de la app)",
              "previewImage": "./assets/widget-preview/city-summary-widget.png",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "resizeMode": "none",
              "widgetFeatures": "reconfigurable|configuration_optional",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      "expo-font"
    ]
  }
}